# =====================================================================
# TgContentManager — переменные окружения для первичного подключения.
#
# ВНИМАНИЕ: всё, что НЕ перечислено здесь (Zhipu API key, GitHub token,
# NewsData key, ID целевого канала, системные промпты, интервалы парсинга),
# хранится В БАЗЕ ДАННЫХ и редактируется через интерфейс Telegram-бота.
#
# ЭТОТ файл содержит ТОЛЬКО то, что нельзя достать из чата:
#   - токен бота
#   - список админов
#   - ключи api_id/api_hash для Telethon (userbot)
#   - путь к SQLite-файлу
# =====================================================================

# --- Telegram Bot ---
# Токен от @BotFather.
BOT_TOKEN=

# Telegram-ID администраторов через запятую.
# Узнать свой ID: напиши @userinfobot.
ADMIN_IDS=

# --- Telethon (тихое чтение TG-каналов) ---
# Получить на https://my.telegram.org -> API development tools.
# Если оставить пустым — TG-коллектор отключится, RSS/GitHub/NewsData работают.
TELETHON_API_ID=
TELETHON_API_HASH=
# Путь к session-файлу Telethon (создаётся при первом запуске с TTY).
TELETHON_SESSION=sessions/telethon

# --- База данных ---
# По умолчанию SQLite в ./data/content.db. Можно переопределить.
# DATABASE_URL=sqlite+aiosqlite:///./data/content.db

# --- LLM-провайдер (переопределение на уровне deployment) ---
# Эти переменные ВЫИГРЫВАЮТ над значениями в БД. Оставь пустыми, чтобы
# управлять ими через чат бота (🧠 Настройки ИИ).
#
# Используется любой OpenAI-совместимый API: Zhipu (https://open.bigmodel.cn/),
# OpenAI, Ollama, vLLM, Together AI и т.д.
#
# Базовый URL провайдера. По умолчанию из БД: https://open.bigmodel.cn/api/paas/v4/
# AI_BASE_URL=
#
# Закрепить конкретные модели (иначе из БД: glm-4-flash / glm-4).
# AI_MODEL_COLLECTOR=glm-4-flash
# AI_MODEL_WRITER=glm-4

# --- Временная директория под медиа ---
# На Ubuntu рекомендуется /tmp. По умолчанию ./tmp внутри проекта.
# TMP_DIR=/tmp

# --- Логирование ---
# INFO / DEBUG / WARNING
LOG_LEVEL=INFO
